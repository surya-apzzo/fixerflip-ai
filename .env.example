PROJECT_NAME="FastAPI Production App"
ENVIRONMENT="local"
DEBUG=false
LOG_LEVEL="INFO"
LOG_JSON=false

BACKEND_CORS_ORIGINS=["http://localhost:3000"]
TRUSTED_HOSTS=[]

# Optional JSON object for request-validation overrides.
# Example:
# VALIDATION_RULE_OVERRIDES='{"sqft":{"minimum":500,"min_inclusive":true},"labor_index":{"maximum":3.0}}'
VALIDATION_RULE_OVERRIDES={}

OPENAI_VISION_ENABLED=false
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o-mini"
OPENAI_IMAGE_EDIT_MODEL="gpt-image-1"
OPENAI_MODEL=""
RENOVATION_IMAGE_STRICT_GUARDRAIL=false

REDIS_URL=""
REDIS_CACHE_TTL_SECONDS=3600

# Optional: some MLS image CDNs require a specific Referer; leave empty to use the image host as Referer.
IMAGE_DOWNLOAD_REFERER=""

# BLS labor trend factor: labor_index/time_factor = current_wage / base_wage.
BLS_API_KEY=""
BLS_BASE_WAGE=34.50
BLS_CONSTRUCTION_WAGE_SERIES_ID="CES2000000008"

# RSMeans/Gordian configuration for ZIP-specific regional location factor.
# Set to the vendor-provided endpoint. You may use a {zip_code} placeholder, e.g.
# RSMEANS_BASE_URL="https://vendor.example.com/v1/cost-indices/{zip_code}"
RSMEANS_API_KEY=""
RSMEANS_BASE_URL=""
LOCATION_INDEX_CACHE_TTL_SECONDS=2592000

# --- Optional: S3-compatible storage for renovated preview uploads ---
# STORAGE_ENDPOINT_URL=
# STORAGE_REGION=auto
# STORAGE_BUCKET_NAME=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# Permanent links (no ?X-Amz-Expires=...): set a public or CDN base URL. Returned URL = base + "/" + key.
# Example R2 public: https://pub-xxxxx.r2.dev  or custom domain: https://cdn.example.com
# STORAGE_PUBLIC_BASE_URL=
# STORAGE_RENOVATED_IMAGE_PREFIX=renovated
# If STORAGE_PUBLIC_BASE_URL is empty, the API returns presigned URLs (they expire; max TTL below).
# STORAGE_PRESIGNED_URL_TTL_SECONDS=3600
