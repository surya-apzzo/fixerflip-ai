PROJECT_NAME="FastAPI Production App"
ENVIRONMENT="local"
DEBUG=false
LOG_LEVEL="INFO"
LOG_JSON=false

BACKEND_CORS_ORIGINS=["http://localhost:3000"]
TRUSTED_HOSTS=[]

# Optional JSON object for request-validation overrides.
# Example:
# VALIDATION_RULE_OVERRIDES='{"sqft":{"minimum":500,"min_inclusive":true},"labor_index":{"maximum":3.0}}'
VALIDATION_RULE_OVERRIDES={}

OPENAI_VISION_ENABLED=false
# POST /condition-score: timeout per vision chunk (many listing photos need 120–180s).
OPENAI_CONDITION_SCORE_VISION_TIMEOUT_SECONDS=180
# Images per OpenAI call (vision analyzes at most ~6 rooms after dedupe).
CONDITION_SCORE_VISION_CHUNK_SIZE=6
OPENAI_CONDITION_SCORE_VISION_MAX_RETRIES=1
# Large MLS feeds: evenly sample up to N URLs for download/CLIP (default 150). Vision still uses <=6 rooms.
CONDITION_SCORE_MAX_INPUT_URLS=150
CONDITION_SCORE_DOWNLOAD_CONCURRENCY=8
# CLIP: strict house-label softmax floor (0.04 works better than 0.07 for MLS interiors).
CONDITION_SCORE_CLIP_MIN_HOUSE_PROB=0.04
# When few photos pass the strict floor, keep top house-scored images until this count.
CONDITION_SCORE_CLIP_MIN_PHOTOS=6
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o-mini"
OPENAI_IMAGE_EDIT_MODEL="gpt-image-1"
# Per-attempt timeout (seconds) for images.edit; raise if edits often time out (see logs: APITimeoutError).
OPENAI_IMAGE_EDIT_TIMEOUT_SECONDS=120
# Retries after first failure for rate limits / timeouts / 5xx (each attempt uses the full timeout above).
OPENAI_IMAGE_EDIT_MAX_RETRIES=1
OPENAI_MODEL=""
RENOVATION_IMAGE_STRICT_GUARDRAIL=false
# When false (default), renovation preview returns the first successful edited upload. When true, a repair-only
# guardrail may re-run edits for heavy-damage photos. Optional refresh: GET /api/v1/bucket/file?key=<object-key>

REDIS_URL=""
REDIS_CACHE_TTL_SECONDS=3600

# Optional: MLS/CDN image download (shared fallback when flow-specific vars are empty).
# crmls.org / cotality.com hosts get automatic Referer; override per feed if needed.
IMAGE_DOWNLOAD_REFERER=""
IMAGE_DOWNLOAD_PROXY_TEMPLATE=""

# Renovation estimate / image edit (POST /renovation/estimate, images.edit)
# For imagecdn.realty.dev/.../CRMLS/... use https://www.crmls.org/ or leave empty (auto from URL path).
RENOVATION_IMAGE_DOWNLOAD_REFERER=""
# Optional; non-Trestle CDNs only. Trestle/Cotality URLs use OAuth Bearer (no weserv proxy).
RENOVATION_IMAGE_DOWNLOAD_PROXY_TEMPLATE=""
# Renovation stages listing photos to S3 first, then vision/edit use the bucket URL.
# STORAGE_RENOVATION_LISTING_IMAGE_PREFIX="renovation/listings"
# Set STORAGE_PUBLIC_BASE_URL so staged_source_image_url is a stable public CDN URL.
# When Cotality blocks Railway: send source_image_base64 (photo from your app) or pre-warm cache from local.

# Condition score (POST /condition-score, image_urls only).
CONDITION_SCORE_IMAGE_DOWNLOAD_REFERER=""
CONDITION_SCORE_IMAGE_DOWNLOAD_PROXY_TEMPLATE=""

# Cotality Trestle OAuth2 — required for api.cotality.com/trestle/Media/* photo downloads.
TRESTLE_BASE_URL="https://api.cotality.com"
TRESTLE_CLIENT_ID=""
TRESTLE_CLIENT_SECRET=""
# TRESTLE_TOKEN_PATH="/trestle/oidc/connect/token"
# TRESTLE_TOKEN_SCOPE="api"
# Required when Cotality Incapsula blocks Railway (token + media). Residential/egress proxy:
# TRESTLE_HTTP_PROXY="http://user:pass@proxy.example:8080"
# On Railway set ENVIRONMENT=production (not local).

# Cached listing photos for condition-score (read from S3 when Cotality blocks direct download).
# STORAGE_CONDITION_SCORE_IMAGE_PREFIX="condition-score/listings"

# BLS labor trend factor: labor_index/time_factor = current_wage / base_wage.
BLS_API_KEY=""
BLS_BASE_WAGE=34.50
BLS_CONSTRUCTION_WAGE_SERIES_ID="CES2000000008"

# RSMeans/Gordian configuration for ZIP-specific regional location factor.
# Set to the vendor-provided endpoint. You may use a {zip_code} placeholder, e.g.
# RSMEANS_BASE_URL="https://vendor.example.com/v1/cost-indices/{zip_code}"
RSMEANS_API_KEY=""
RSMEANS_BASE_URL=""
LOCATION_INDEX_CACHE_TTL_SECONDS=2592000

# --- Optional: S3-compatible storage for renovated preview uploads ---
# STORAGE_ENDPOINT_URL=
# STORAGE_REGION=auto
# STORAGE_BUCKET_NAME=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# Optional CDN/public base (unsigned fallback only if presign fails and STORAGE_RENOVATED_RESPONSE_USE_PUBLIC_URL=true).
# STORAGE_PUBLIC_BASE_URL=
# STORAGE_RENOVATED_RESPONSE_USE_PUBLIC_URL=false
# STORAGE_RENOVATED_IMAGE_PREFIX=renovated
# Default: API returns presigned URLs (private Railway buckets open in browser). TTL:
# STORAGE_PRESIGNED_URL_TTL_SECONDS=3600
